  "keyFeatures": [
    "500+ coding vocabulary terms across 24 categories",
    "Flashcard and quiz learning modes",
    "Spaced repetition system (SRS) for optimized learning",
    "ELI5 mode with beginner-friendly definitions",
    "Achievement system with 30+ unlockable badges",
    "Daily streak tracking and goal setting",
    "Offline-first with local storage via Capacitor",
    "Mobile-ready with Android app support",
    "Dark mode and theme customization",
    "Progress tracking per category and term"
  ],
  "publicApiSurface": [
    "useProgress hook - Main progress tracking and state management",
    "useDailyGoals hook - Daily goal tracking and widget state",
    "useSpeech hook - Text-to-speech functionality",
    "SM2 algorithm (lib/sm2.ts) - Spaced repetition calculations",
    "vocabulary.ts - 500+ term definitions with categories",
    "achievements.ts - Achievement conditions and unlocking logic",
    "FlashCard component - Interactive card with flip and swipe",
    "QuizMode component - Multiple choice quiz interface",
    "CategoryCard component - Category selection tiles",
    "AchievementsModal component - Achievement display and tracking"
  ]
